{
  "name": "zns-client",
  "version": "1.1.0",
  "description": "ZNS – Zentrales Nachrichten-System | Electron-Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "de.praxis.zns",
    "productName": "ZNS",
    "copyright": "Copyright © 2026 lolly",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "signingHashAlgorithms": null,
      "forceCodeSigning": false
    },
    "portable": {
      "artifactName": "ZNS-Client.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/ws/**"
    ]
  },
  "author": "lolly",
  "license": "MIT"
}